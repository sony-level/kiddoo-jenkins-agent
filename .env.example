# =============================================================================
# kiddoo-jenkins-agent — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- AWS Configuration -------------------------------------------------------
AWS_REGION=eu-west-3

# --- EC2 Instance ------------------------------------------------------------
INSTANCE_TYPE=t3.micro
ROOT_VOLUME_GIB=30

# --- SSH Configuration -------------------------------------------------------
SSH_PORT=2222
# SSH_CIDR=           # e.g. 203.0.113.10/32  (auto-detected if empty)
# SSH_PUBLIC_KEY_FILE= # e.g. ~/.ssh/id_ed25519.pub

# --- Network (leave empty to use default VPC/Subnet) -------------------------
# VPC_ID=
# SUBNET_ID=

# --- Discord Notifications (leave empty to disable) --------------------------
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN
